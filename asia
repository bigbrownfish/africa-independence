let currentMode = "independence";

// --- ЛОГИКА ЛЕГЕНДЫ И КНОПОК ---
const legendHeader = document.getElementById('legend-header');
const legendEl = document.getElementById('legend');
const modeBtns = document.querySelectorAll('.mode-btn');

modeBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
        modeBtns.forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        currentMode = e.target.dataset.mode;
        updateMapVisuals();
    });
});

let isDragging = false; let isMoved = false; let startX, startY, initialLeft, initialTop;

legendHeader.addEventListener("pointerdown", (e) => {
    if (window.innerWidth <= 600) return; 
    isDragging = true; isMoved = false; 
    startX = e.clientX; startY = e.clientY;
    const rect = legendEl.getBoundingClientRect();
    legendEl.style.bottom = "auto"; legendEl.style.right = "auto";
    initialLeft = rect.left; initialTop = rect.top;
    legendEl.style.left = initialLeft + "px"; legendEl.style.top = initialTop + "px";
    legendHeader.setPointerCapture(e.pointerId);
});

legendHeader.addEventListener("pointermove", (e) => {
    if (!isDragging) return;
    const dx = e.clientX - startX; const dy = e.clientY - startY;
    if (Math.abs(dx) > 3 || Math.abs(dy) > 3) isMoved = true;
    if (isMoved) {
        let newX = Math.max(0, Math.min(window.innerWidth - legendEl.offsetWidth, initialLeft + dx));
        let newY = Math.max(document.getElementById('top-nav').offsetHeight, Math.min(window.innerHeight - legendEl.offsetHeight, initialTop + dy));
        legendEl.style.left = newX + "px"; legendEl.style.top = newY + "px";
    }
});

legendHeader.addEventListener("pointerup", (e) => {
    if (window.innerWidth > 600) {
        isDragging = false; legendHeader.releasePointerCapture(e.pointerId);
        if (!isMoved) legendEl.classList.toggle('collapsed');
    }
});

legendHeader.addEventListener('click', () => { if(window.innerWidth <= 600) legendEl.classList.toggle('collapsed'); });

function updateLegend() {
    const container = d3.select("#legend-items");
    container.html("");
    if (currentMode === "independence") {
        Object.entries(metropoleColors).forEach(([metro, color]) => {
            const item = container.append("div").attr("class", "legend-item");
            item.append("div").attr("class", "legend-color").style("background-color", color);
            item.append("div").text(metro);
        });
        const mixedItem = container.append("div").attr("class", "legend-item").style("margin-top", "8px");
        mixedItem.append("div").attr("class", "legend-pattern");
        mixedItem.append("div").style("font-style", "italic").style("font-size", "11px").text("Штриховка: Несколько метрополий");
    } else {
        Object.entries(subregionColors).forEach(([region, color]) => {
            const item = container.append("div").attr("class", "legend-item");
            item.append("div").attr("class", "legend-color").style("background-color", color);
            item.append("div").text(region);
        });
    }
}

// --- D3.js КАРТА ---
const svg = d3.select("#map-container");
const defs = svg.append("defs");
const mapGroup = svg.append("g"); 
const projection = d3.geoMercator();
const path = d3.geoPath().projection(projection);
const tooltip = d3.select("#tooltip");

const zoom = d3.zoom().scaleExtent([0.5, 15]).on("zoom", function(event) {
    const k = event.transform.k;
    mapGroup.attr("transform", event.transform);
    mapGroup.selectAll(".country").style("stroke-width", 0.5 / k + "px");
    
    mapGroup.selectAll(".island-marker")
        .attr("r", 3 / Math.max(1, k * 0.4))
        .style("stroke-width", 0.8 / k + "px");

    mapGroup.selectAll(".island-label")
        .style("font-size", (8 / Math.max(1, k * 0.5)) + "px")
        .style("opacity", k > 3.5 ? 1 : 0);

    mapGroup.selectAll(".map-label")
        .style("font-size", (9 / Math.max(1, k * 0.4)) + "px");

    hideTooltip();
});
svg.call(zoom);

function resizeMap() {
    const navHeight = document.getElementById('top-nav').offsetHeight;
    const w = window.innerWidth; const h = window.innerHeight - navHeight;
    svg.attr("width", w).attr("height", h);
    zoom.translateExtent([[-w, -h], [w * 2, h * 2]]); 
}
window.addEventListener('resize', resizeMap);
resizeMap();

function getIndependenceColor(dataObj, id) {
    const metros = dataObj.metro;
    if (metros.length === 1) return metropoleColors[metros[0]] || "#ececec";
    const patternId = "pattern-" + id;
    if (defs.select(`#${patternId}`).empty()) {
        const pattern = defs.append("pattern").attr("id", patternId).attr("patternUnits", "userSpaceOnUse").attr("width", metros.length * 6).attr("height", metros.length * 6).attr("patternTransform", "rotate(45)");
        metros.forEach((metro, index) => { pattern.append("rect").attr("x", index * 6).attr("y", 0).attr("width", 6).attr("height", metros.length * 6).attr("fill", metropoleColors[metro] || "#ececec"); });
    }
    return `url(#pattern-${id})`;
}

function getFillStyle(dataObj, id) {
    if (currentMode === "quiz") return (quizPhase === 'result' || (quizPhase === 'answer' && id === currentTargetId)) ? getIndependenceColor(dataObj, id) : "#ececec";
    if (currentMode === "subregions") return subregionColors[dataObj.subregion] || "#ececec";
    return getIndependenceColor(dataObj, id);
}

function showTooltip(event, info) {
    if (currentMode === "quiz") return; 
    tooltip.transition().duration(200).style("opacity", 1);
    
    let xPos = event.pageX + 15; 
    let yPos = event.pageY - 28;
    if (xPos + 290 > window.innerWidth) xPos = window.innerWidth - 300;
    
    let tooltipHtml = `<div class="tooltip-title">${info.name}</div><div class="tooltip-row"><b>Субрегион:</b> ${info.subregion}</div>`;
    if (currentMode === "independence") {
        tooltipHtml += `<div class="tooltip-row"><b>Год независимости:</b> ${info.year}</div>
                        <div class="tooltip-row"><b>Метрополии:</b> ${info.metro_text}</div>`;
    } else {
        tooltipHtml += `<div class="tooltip-row"><b>Столица (Адм. центр):</b> ${info.capital}</div>`;
    }
    tooltipHtml += `<div class="tooltip-row"><b>Оф. языки:</b> ${info.lang}</div>`;
    
    tooltip.html(tooltipHtml).style("left", Math.max(10, xPos) + "px").style("top", Math.max(10, yPos) + "px");
}

function hideTooltip() { tooltip.transition().duration(200).style("opacity", 0); }
svg.on("click", hideTooltip); 

function resolveGeoId(d) {
    const prop = d.properties || {};
    const idCandidates = [d.id, prop.ADM0_A3, prop.ISO_A3, prop.GU_A3, prop.SU_A3];
    for (let id of idCandidates) {
        if (!id || id === "-99") continue;
        if (countryData[id]) return id;
        if (id === "CYN") return "CYP"; // Привязка Северного Кипра к Кипру
        if (id === "PSX") return "PSE"; // Палестина
    }
    const name = prop.NAME || prop.ADMIN || prop.name;
    if (name === "Taiwan") return "TWN";
    return null;
}

let geojsonData = [];

function updateMapVisuals() {
    updateLegend();
    mapGroup.selectAll(".country").attr("fill", d => {
        const geoId = resolveGeoId(d);
        return countryData[geoId] ? getFillStyle(countryData[geoId], geoId) : "#ececec";
    }).style("stroke-width", d => (currentMode === 'quiz' && resolveGeoId(d) === currentTargetId && quizPhase !== 'find') ? "2px" : "0.5px")
      .style("stroke", d => (currentMode === 'quiz' && resolveGeoId(d) === currentTargetId && quizPhase !== 'find') ? "#e74c3c" : "#333");

    mapGroup.selectAll(".island-marker").attr("fill", d => getFillStyle(d.info, d.id));
    
    mapGroup.selectAll(".map-label").text(d => {
        if (currentMode === "quiz") return "";
        const geoId = resolveGeoId(d);
        if (!countryData[geoId]) return "";
        return currentMode === "independence" ? countryData[geoId].year.split(' ')[0] : "";
    });
    mapGroup.selectAll(".island-label").text(d => (currentMode === "independence" && currentMode !== "quiz") ? d.info.year.split(' ')[0] : "");
}

// --- ЛОГИКА ТЕСТИРОВАНИЯ (QUIZ) ---
let quizCountriesList = [];
let currentQuizIndex = 0;
let quizPhase = "off";
let currentQuizTargetId = null;
let selectedMetros = {};

const quizPanel = document.getElementById('quiz-panel');
const metroSelect = document.getElementById('quiz-metro-select');

Object.keys(metropoleColors).forEach(metro => {
    let opt = document.createElement('option');
    opt.value = metro; opt.textContent = metro;
    metroSelect.appendChild(opt);
});

metroSelect.addEventListener('change', function() {
    const val = this.value;
    if (val && !selectedMetros[val]) { selectedMetros[val] = ""; renderSelectedMetros(); }
    this.value = ""; 
});

function renderSelectedMetros() {
    const container = document.getElementById('quiz-selected-metros');
    container.innerHTML = "";
    Object.keys(selectedMetros).forEach(metro => {
        const row = document.createElement('div');
        row.className = "quiz-metro-item";
        row.innerHTML = `<span>${metro}</span><div><span style="font-size: 11px;">до: </span>
                <input type="text" class="quiz-metro-year" data-metro="${metro}" placeholder="Год" value="${selectedMetros[metro]}">
                <button class="quiz-remove-btn" onclick="removeMetro('${metro}')">×</button></div>`;
        container.appendChild(row);
    });
    document.querySelectorAll('.quiz-metro-year').forEach(input => {
        input.addEventListener('input', (e) => { selectedMetros[e.target.dataset.metro] = e.target.value; });
    });
}

window.removeMetro = function(metro) { delete selectedMetros[metro]; renderSelectedMetros(); }

function startQuiz() {
    const allIds = [...Object.keys(countryData), ...islandNations.map(i => i.id)];
    quizCountriesList = allIds.sort(() => Math.random() - 0.5); 
    currentQuizIndex = 0;
    legendEl.style.display = 'none';
    quizPanel.style.display = 'block';
    nextQuizQuestion();
}

function getCountryNameById(id) {
    if (countryData[id]) return countryData[id].name;
    let island = islandNations.find(i => i.id === id);
    if (island) return island.info.name;
    return "";
}

function nextQuizQuestion() {
    if (currentQuizIndex >= quizCountriesList.length) {
        document.getElementById('quiz-find-section').innerHTML = "<div class='quiz-title'>Тест завершен! Вы прошли все территории.</div>";
        document.getElementById('quiz-answer-section').style.display = 'none';
        return;
    }
    currentTargetId = quizCountriesList[currentQuizIndex];
    quizPhase = 'find'; selectedMetros = {};
    document.getElementById('quiz-target-name').textContent = getCountryNameById(currentTargetId);
    document.getElementById('quiz-error-msg').textContent = "";
    document.getElementById('quiz-find-section').style.display = 'block';
    document.getElementById('quiz-answer-section').style.display = 'none';
    document.getElementById('quiz-result').style.display = 'none';
    document.getElementById('quiz-next-btn').style.display = 'none';
    document.getElementById('quiz-check-btn').style.display = 'block';
    document.getElementById('quiz-year-input').value = "";
    renderSelectedMetros(); updateMapVisuals();
}

function handleQuizMapClick(geoId) {
    if (quizPhase !== 'find') return;
    if (geoId === currentTargetId) {
        quizPhase = 'answer';
        document.getElementById('quiz-find-section').style.display = 'none';
        document.getElementById('quiz-active-name').textContent = getCountryNameById(currentTargetId);
        document.getElementById('quiz-answer-section').style.display = 'block';
        updateMapVisuals(); 
    } else {
        const clickedName = getCountryNameById(geoId) || "Неизвестная территория";
        document.getElementById('quiz-error-msg').textContent = `Неверно! Это ${clickedName}. Ищите ${getCountryNameById(currentTargetId)}!`;
    }
}

document.getElementById('quiz-check-btn').addEventListener('click', () => {
    const targetData = countryData[currentTargetId] || islandNations.find(i => i.id === currentTargetId).info;
    const inputYear = document.getElementById('quiz-year-input').value.trim();
    let errors = [];
    
    if (!targetData.year.includes(inputYear) || inputYear === "") {
        errors.push(`<b>Год независимости:</b> неверно. Правильно: ${targetData.year}`);
    }
    
    const targetMetros = targetData.metro;
    const selectedMetroKeys = Object.keys(selectedMetros);
    let missingMetros = targetMetros.filter(m => !selectedMetroKeys.includes(m));
    let extraMetros = selectedMetroKeys.filter(m => !targetMetros.includes(m));
    
    if (missingMetros.length > 0) errors.push(`<b>Пропущены:</b> ${missingMetros.join(', ')}`);
    if (extraMetros.length > 0) errors.push(`<b>Лишние:</b> ${extraMetros.join(', ')}`);
    
    selectedMetroKeys.forEach(m => {
        if (targetMetros.includes(m)) {
            const inputDate = selectedMetros[m].trim();
            if (inputDate !== "" && !targetData.metro_text.includes(inputDate)) {
                 errors.push(`<b>Дата для ${m}:</b> неверно.`);
            } else if (inputDate === "") errors.push(`<b>Укажите дату для ${m}</b>`);
        }
    });

    const resultBox = document.getElementById('quiz-result');
    resultBox.style.display = 'block';
    if (errors.length === 0) {
        resultBox.className = "quiz-result-box correct";
        resultBox.innerHTML = `<strong>Идеально!</strong><br>Полная справка: ${targetData.metro_text}`;
    } else {
        resultBox.className = "quiz-result-box incorrect";
        resultBox.innerHTML = `<strong>Есть ошибки:</strong><br>${errors.join('<br>')}<br><br><em>Справка: ${targetData.metro_text}</em>`;
    }
    
    document.getElementById('quiz-check-btn').style.display = 'none';
    document.getElementById('quiz-next-btn').style.display = 'block';
    quizPhase = 'result'; updateMapVisuals(); 
});

document.getElementById('quiz-next-btn').addEventListener('click', () => { currentQuizIndex++; nextQuizQuestion(); });

// 100% НАДЕЖНАЯ ЗАГРУЗКА КАРТЫ
const localUrl = "ne_110m_admin_0_countries.geojson";
const cdnUrl = "https://raw.githubusercontent.com/holtzy/D3-graph-gallery/master/DATA/world.geojson";

d3.json(localUrl).catch(() => d3.json(cdnUrl)).then(world => {
    geojsonData = world.features.filter(d => resolveGeoId(d) !== null);
    
    // Центрируем карту на Азию
    projection.fitExtent([[30, 30], [window.innerWidth - 30, window.innerHeight - document.getElementById('top-nav').offsetHeight - 30]], {type: "FeatureCollection", features: geojsonData});

    mapGroup.selectAll("path").data(geojsonData).enter().append("path").attr("d", path).attr("class", "country")
        .on("click", (event, d) => { 
            event.stopPropagation(); 
            const geoId = resolveGeoId(d);
            if (!geoId || !countryData[geoId]) return;
            if (currentMode === 'quiz') handleQuizMapClick(geoId); else showTooltip(event, countryData[geoId]); 
        });

    mapGroup.selectAll(".map-label").data(geojsonData).enter().append("text").attr("class", "map-label").attr("transform", d => {
            const centroid = path.centroid(d);
            return (!isNaN(centroid[0]) && !isNaN(centroid[1])) ? `translate(${centroid[0]}, ${centroid[1]})` : "translate(-1000,-1000)"; 
        });

    const islands = mapGroup.selectAll(".island-group").data(islandNations).enter().append("g")
        .attr("transform", d => `translate(${projection(d.coords)[0]}, ${projection(d.coords)[1]})`);

    islands.append("circle").attr("class", "island-marker").attr("r", 3)
        .on("click", (event, d) => { 
            event.stopPropagation(); 
            if (currentMode === 'quiz') handleQuizMapClick(d.id); else showTooltip(event, d.info); 
        });

    islands.append("text").attr("class", "island-label").attr("dx", 6).attr("dy", 2);
    updateMapVisuals();
}).catch(error => {
    alert("Критическая ошибка загрузки карты.");
});
</script>
